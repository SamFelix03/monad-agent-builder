# Monad Testnet RPC (default: https://testnet-rpc.monad.xyz)
MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# Moralis API — wallet analytics (https://docs.monad.xyz/guides/moralis-api)
MORALIS_API_KEY=
MORALIS_CHAIN=0x279f

# Groq — AI token price queries
GROQ_API_KEY=

# Pinata — NFT metadata IPFS uploads
PINATA_API_KEY=
PINATA_SECRET_KEY=

# Deployed contract addresses (set after running backend/scripts/deploy-monad.sh)
TOKEN_FACTORY_ADDRESS=
NFT_FACTORY_ADDRESS=
DAO_FACTORY_ADDRESS=
AIRDROP_CONTRACT_ADDRESS=
YIELD_CALCULATOR_ADDRESS=

# Optional overrides
PORT=3000
KURU_FLOW_API=https://ws.kuru.io
WMON_ADDRESS=0xFb8bf4c1CC7a94c73D209a149eA2AbEa852BC541
